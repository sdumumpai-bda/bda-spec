{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(rg:*)",
      "Bash(date:*)",
      "Bash(wc:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(./scripts/*:*)"
    ],
    "ask": [
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git checkout:*)",
      "Bash(git merge:*)",
      "Bash(git rebase:*)",
      "Bash(npm:*)",
      "Bash(pnpm:*)",
      "Bash(yarn:*)",
      "Bash(dotnet:*)",
      "Bash(flutter:*)"
    ],
    "deny": [
      "Bash(rm -rf /:*)",
      "Bash(:(){:|:&};:)",
      "Bash(curl * | sh)",
      "Bash(curl * | bash)",
      "Bash(sudo:*)"
    ]
  },
  "env": {
    "BDA_SPEC_ROOT": ".",
    "BDA_SPEC_VAULT": "docs"
  }
}
